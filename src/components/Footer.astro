---
const currentYear = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;

const DRIVE_LINK = "YOUR_GOOGLE_DRIVE_LINK_HERE";
const PASSWORD = "ROSE";

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/startups', label: 'Startups' },
  { href: '/events', label: 'Events' },
  { href: '/resources', label: 'Resources' },
  { href: '/team', label: 'Team' },
  { href: '/contact', label: 'Contact' },
];

const socialLinks = [
  { href: '#', label: 'Instagram', icon: '📷' },
  { href: '#', label: 'LinkedIn', icon: '💼' },
  { href: '#', label: 'Twitter', icon: '🐦' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src={`${baseUrl}/seclogo.jpeg`} alt="MGoKBSEC Logo" width="50" height="50" />
          <span>MGoKBSEC</span>
        </a>
        <p class="footer-tagline">
          Empowering student entrepreneurs at Manipal Government of Karnataka BioIncubator
        </p>
      </div>
      
      <div class="footer-links">
        <h4>Quick Links</h4>
        <nav>
          {quickLinks.map(link => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>
      
      <div class="footer-contact">
        <h4>Connect With Us</h4>
        <div class="social-links">
          {socialLinks.map(link => (
            <a href={link.href} aria-label={link.label} title={link.label}>
              <span class="social-icon">{link.icon}</span>
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <div class="footer-locked">
        <h4>Exclusive Content</h4>
        <button class="lock-button" id="openLockModal" aria-label="Access locked content">
          <img src={`${baseUrl}/lock.svg`} alt="Lock" width="40" height="40" />
          <span>Members Area</span>
        </button>
      </div>
    </div>

    <dialog id="lockModal" class="lock-modal">
      <div class="lock-modal-content">
        <button class="close-modal" id="closeLockModal" aria-label="Close">&times;</button>
        <img src={`${baseUrl}/lock.svg`} alt="Lock" width="60" height="60" />
        <h3>Enter Password</h3>
        <p>Access exclusive members content</p>
        <form id="lockForm">
          <input type="password" id="lockPassword" placeholder="Enter password" required />
          <p class="lock-error" id="lockError">Incorrect password. Try again.</p>
          <button type="submit" class="btn btn-primary">Unlock</button>
        </form>
      </div>
    </dialog>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} MGoKBSEC. All rights reserved.</p>
      <p>Student Entrepreneurship Cell | Manipal Government of Karnataka BioIncubator</p>
    </div>
  </div>
</footer>

<script>
  const openBtn = document.getElementById('openLockModal');
  const closeBtn = document.getElementById('closeLockModal');
  const modal = document.getElementById('lockModal');
  const form = document.getElementById('lockForm');
  const passwordInput = document.getElementById('lockPassword');
  const errorMsg = document.getElementById('lockError');

  const CORRECT_PASSWORD = "ROSE";
  const DRIVE_LINK = "YOUR_GOOGLE_DRIVE_LINK_HERE";

  openBtn?.addEventListener('click', () => {
    modal?.showModal();
    passwordInput?.focus();
  });

  closeBtn?.addEventListener('click', () => {
    modal?.close();
    if (passwordInput) passwordInput.value = '';
    if (errorMsg) errorMsg.style.display = 'none';
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.close();
      if (passwordInput) passwordInput.value = '';
      if (errorMsg) errorMsg.style.display = 'none';
    }
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (passwordInput?.value.toLowerCase() === CORRECT_PASSWORD.toLowerCase()) {
      window.location.href = DRIVE_LINK;
    } else {
      if (errorMsg) {
        errorMsg.style.display = 'block';
        passwordInput.value = '';
        passwordInput.focus();
      }
    }
  });
</script>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-white);
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-white);
    margin-bottom: 1rem;
  }
  
  .footer-logo img {
    border-radius: var(--radius-sm);
  }
  
  .footer-tagline {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    max-width: 300px;
  }
  
  .footer-links h4,
  .footer-contact h4,
  .footer-locked h4 {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--color-accent-light);
  }

  .lock-button {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    padding: 1rem;
    cursor: pointer;
    transition: var(--transition);
    color: var(--color-white);
  }

  .lock-button:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-2px);
  }

  .lock-button span {
    font-size: 0.85rem;
  }

  .lock-modal {
    border: none;
    border-radius: var(--radius-lg);
    padding: 0;
    background: var(--color-white);
    color: var(--color-text);
    max-width: 400px;
    width: 90%;
    box-shadow: var(--shadow-lg);
  }

  .lock-modal::backdrop {
    background: rgba(0, 0, 0, 0.6);
  }

  .lock-modal-content {
    padding: 2rem;
    text-align: center;
    position: relative;
  }

  .lock-modal-content h3 {
    color: var(--color-primary);
    margin: 1rem 0 0.5rem;
  }

  .lock-modal-content > p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .close-modal {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--color-text-light);
    padding: 0;
    line-height: 1;
  }

  .close-modal:hover {
    color: var(--color-text);
  }

  #lockForm {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  #lockPassword {
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-family: var(--font-body);
    text-align: center;
  }

  #lockPassword:focus {
    outline: none;
    border-color: var(--color-secondary);
  }

  .lock-error {
    color: #dc3545;
    font-size: 0.85rem;
    margin: 0;
    display: none;
  }
  
  .footer-links nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .footer-links a {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    transition: var(--transition);
  }
  
  .footer-links a:hover {
    color: var(--color-white);
    padding-left: 0.5rem;
  }
  
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    transition: var(--transition);
  }
  
  .social-links a:hover {
    color: var(--color-white);
  }
  
  .social-icon {
    font-size: 1.2rem;
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 2rem;
    text-align: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
  }
  
  .footer-bottom p:first-child {
    margin-bottom: 0.5rem;
  }
  
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-locked {
      grid-column: span 2;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    
    .footer-links nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-locked {
      grid-column: span 1;
    }
  }
</style>
