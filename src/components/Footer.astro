---
const currentYear = new Date().getFullYear();
const baseUrl = import.meta.env.BASE_URL;

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/startups', label: 'Startups' },
  { href: '/events', label: 'Events' },
  { href: '/resources', label: 'Resources' },
  { href: '/team', label: 'Team' },
  { href: '/contact', label: 'Contact' },
];

const socialLinks = [
  { href: '#', label: 'Instagram', icon: '📷' },
  { href: '#', label: 'LinkedIn', icon: '💼' },
  { href: '#', label: 'Twitter', icon: '🐦' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src={`${baseUrl}/seclogo.jpeg`} alt="MGoKBSEC Logo" width="50" height="50" />
          <span>MGoKBSEC</span>
        </a>
        <p class="footer-tagline">
          Empowering student entrepreneurs at Manipal Government of Karnataka BioIncubator
        </p>
      </div>
      
      <div class="footer-links">
        <h4>Quick Links</h4>
        <nav>
          {quickLinks.map(link => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>
      
      <div class="footer-contact">
        <h4>Connect With Us</h4>
        <div class="social-links">
          {socialLinks.map(link => (
            <a href={link.href} aria-label={link.label} title={link.label}>
              <span class="social-icon">{link.icon}</span>
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p>&copy; {currentYear} MGoKBSEC. All rights reserved.</p>
      <p>Student Entrepreneurship Cell | Karnataka BioIncubator</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-white);
    padding: 4rem 0 2rem;
    margin-top: 4rem;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-white);
    margin-bottom: 1rem;
  }
  
  .footer-logo img {
    border-radius: var(--radius-sm);
  }
  
  .footer-tagline {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    max-width: 300px;
  }
  
  .footer-links h4,
  .footer-contact h4 {
    font-size: 1rem;
    margin-bottom: 1rem;
    color: var(--color-accent-light);
  }
  
  .footer-links nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .footer-links a {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    transition: var(--transition);
  }
  
  .footer-links a:hover {
    color: var(--color-white);
    padding-left: 0.5rem;
  }
  
  .social-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  
  .social-links a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    transition: var(--transition);
  }
  
  .social-links a:hover {
    color: var(--color-white);
  }
  
  .social-icon {
    font-size: 1.2rem;
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 2rem;
    text-align: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
  }
  
  .footer-bottom p:first-child {
    margin-bottom: 0.5rem;
  }
  
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .footer-links nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
</style>
