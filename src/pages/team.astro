---
import Layout from '../layouts/Layout.astro';
import { coreTeam, advisors, mentors } from '../data/team';
---

<Layout title="Team" description="Meet the team behind MGoKBSEC - student entrepreneurs, faculty advisors, and mentors">
  <section class="page-header">
    <div class="container">
      <h1>Our Team</h1>
      <p>The people driving innovation and entrepreneurship at MGoKBSEC</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="team-section">
        <h2 class="section-title">Faculty Advisors</h2>
        <p class="section-subtitle">Guiding our vision and providing academic expertise</p>
        
        <div class="advisors-grid">
          {advisors.map(person => (
            <div class="advisor-card">
              <div class="advisor-avatar">
                <span>👨‍🏫</span>
              </div>
              <div class="advisor-info">
                <h3>{person.name}</h3>
                <p class="advisor-role">{person.role}</p>
                <p class="advisor-dept">{person.department}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section team-section-alt">
    <div class="container">
      <div class="team-section">
        <h2 class="section-title">Core Team</h2>
        <p class="section-subtitle">Student leaders managing MGoKBSEC operations</p>
        
        <div class="core-team-grid">
          {coreTeam.map(person => (
            <div class="team-card">
              <div class="team-avatar">
                <span>{person.name.split(' ').map(n => n[0]).join('')}</span>
              </div>
              <h3>{person.name}</h3>
              <p class="team-role">{person.role}</p>
              {person.linkedin && (
                <a href={person.linkedin} class="linkedin-link" aria-label="LinkedIn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="team-section">
        <h2 class="section-title">Mentors</h2>
        <p class="section-subtitle">Industry experts providing guidance and expertise</p>
        
        <div class="mentors-grid">
          {mentors.map(person => (
            <div class="mentor-card">
              <div class="mentor-avatar">
                <span>👨‍💼</span>
              </div>
              <div class="mentor-info">
                <h3>{person.name}</h3>
                <p class="mentor-role">{person.role}</p>
                {person.linkedin && (
                  <a href={person.linkedin} class="linkedin-link" target="_blank" rel="noopener">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    LinkedIn
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="container">
      <div class="cta-box">
        <h2>Want to join our team?</h2>
        <p>We're always looking for passionate students to contribute to MGoKBSEC.</p>
        <a href="/contact" class="btn btn-primary">Get Involved</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }
  
  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  
  .page-header p {
    font-size: 1.1rem;
    opacity: 0.9;
  }
  
  .team-section-alt {
    background: var(--color-white);
  }
  
  .advisors-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: center;
  }
  
  .advisor-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--color-white);
    padding: 1.5rem 2rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    min-width: 300px;
  }
  
  .advisor-avatar {
    width: 60px;
    height: 60px;
    background: var(--color-background);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
  }
  
  .advisor-info h3 {
    color: var(--color-primary);
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  
  .advisor-role {
    font-weight: 500;
    color: var(--color-text);
    font-size: 0.9rem;
  }
  
  .advisor-dept {
    color: var(--color-text-light);
    font-size: 0.85rem;
  }
  
  .core-team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  
  .team-card {
    background: var(--color-background);
    padding: 2rem 1.5rem;
    border-radius: var(--radius-lg);
    text-align: center;
    position: relative;
    transition: var(--transition);
  }
  
  .team-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
  
  .team-avatar {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0 auto 1rem;
  }
  
  .team-card h3 {
    color: var(--color-primary);
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }
  
  .team-role {
    color: var(--color-text-light);
    font-size: 0.85rem;
  }
  
  .linkedin-link {
    position: absolute;
    top: 1rem;
    right: 1rem;
    color: #0077B5;
    transition: var(--transition);
  }
  
  .linkedin-link:hover {
    transform: scale(1.2);
  }
  
  .mentors-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  
  .mentor-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--color-white);
    padding: 1.5rem 2rem;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }
  
  .mentor-card:hover {
    box-shadow: var(--shadow-md);
  }
  
  .mentor-avatar {
    width: 70px;
    height: 70px;
    background: var(--color-background);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    flex-shrink: 0;
  }
  
  .mentor-info h3 {
    color: var(--color-primary);
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  
  .mentor-role {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }
  
  .mentor-card .linkedin-link {
    position: static;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.85rem;
  }
  
  .cta-section {
    background: var(--color-background);
  }
  
  .cta-box {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: var(--color-white);
    padding: 3rem;
    border-radius: var(--radius-lg);
    text-align: center;
  }
  
  .cta-box h2 {
    margin-bottom: 0.5rem;
  }
  
  .cta-box p {
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }
  
  .cta-box .btn-primary {
    background: var(--color-white);
    color: var(--color-primary);
  }
  
  .cta-box .btn-primary:hover {
    background: var(--color-background);
  }
  
  @media (max-width: 768px) {
    .core-team-grid { grid-template-columns: repeat(2, 1fr); }
    .mentors-grid { grid-template-columns: 1fr; }
  }
  
  @media (max-width: 480px) {
    .core-team-grid { grid-template-columns: 1fr; }
    .advisor-card { min-width: auto; }
  }
</style>
